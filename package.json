    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.4.4",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
