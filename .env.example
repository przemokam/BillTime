# Copy to .env (gitignored). Local dev uses a SQLite file.
DATABASE_URL="file:./dev.db"

# Optional: only needed for the AI "sum" button when running in Docker (no local
# `claude` CLI). On your dev machine the CLI is used and no key is required.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-haiku-4-5"   # default is claude-opus-4-8; haiku is cheaper
